# Supabase (isolated project only) — استبدل القيم بمشروعك المعزول
# Dashboard: https://app.supabase.com → مشروعك المعزول → Settings → API
VITE_SUPABASE_URL=https://your-isolated-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_isolated_project_anon_key

# Safety switch: keep =0 لمنع الربط العرضي مع مشروع قديم
VITE_ALLOW_LEGACY_SUPABASE=0

# اسم جدول المخزون في Supabase (اختياري، الافتراضي: inventory)
# يجب أن يحتوي الجدول على أعمدة للاسم والكمية والسعر (أو نُسقّي الأسماء في الكود)
VITE_SUPABASE_TABLE=inventory

# جلب صورة المنتج تلقائياً بالباركود (اختياري — مفيد للمكيفات والإلكترونيات)
# أنشئ «Programmable Search Engine» مع تفعيل «Image search» ثم:
# https://developers.google.com/custom-search/v1/overview
# VITE_GOOGLE_CSE_API_KEY=your_api_key
# VITE_GOOGLE_CSE_CX=your_search_engine_id
